{
  "manifest_version": 3,
  "name": "منصة العدالة لإدارة مكاتب المحاماة",
  "version": "2.4.0",
  "description": "أداة هجينة (RPA + قراءة شاشة) لسحب البيانات من ناجز ومزامنتها تلقائياً مع منصة العدالة",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "منصة العدالة — مزامنة ناجز",
    "default_icon": { "48": "icon.png", "128": "icon.png" }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://najiz.sa/*",
        "https://*.najiz.sa/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": { "48": "icon.png", "128": "icon.png" }
}
